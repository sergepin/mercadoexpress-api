# Copiar este archivo a .env antes de correr el proyecto

# --- Local / docker-compose ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=inventory_user
DB_PASSWORD=inventory_pass
DB_NAME=inventory_db

# Base de datos exclusiva para tests e2e (nunca usar inventory_db de desarrollo)
DB_NAME_TEST=inventory_db_test

PORT=3000

# --- Neon / Cloud Run ---
# Preferible: connection string completa (incluye SSL).
# En Neon usa el endpoint "pooled" para la app; para migraciones también suele funcionar.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
#
# Alternativa: variables sueltas + SSL
# DB_HOST=ep-xxxx.us-east-1.aws.neon.tech
# DB_PORT=5432
# DB_USER=neondb_owner
# DB_PASSWORD=...
# DB_NAME=neondb
# DB_SSL=true
