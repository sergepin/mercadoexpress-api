# Copiar este archivo a .env antes de correr el proyecto (docker-compose lo lee automáticamente)

DB_HOST=localhost
DB_PORT=5432
DB_USER=inventory_user
DB_PASSWORD=inventory_pass
DB_NAME=inventory_db

# Base de datos exclusiva para tests e2e (nunca usar inventory_db de desarrollo)
DB_NAME_TEST=inventory_db_test

PORT=3000
